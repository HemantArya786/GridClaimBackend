# ─────────────────────────────────────────────────────────────────────────────
# Live Territory Capture Board — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:3000,https://gridclaim.vercel.app,https://grid-claim-frontend-owox.vercel.app

# ── MongoDB ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://hemant:hemant@cluster0.6w5hjzu.mongodb.net/territory-capture?retryWrites=true&w=majority

# ── Grid Configuration ─────────────────────────────────────────────────────
GRID_ROWS=20
GRID_COLS=20

# ── Rate Limiting ──────────────────────────────────────────────────────────
# Maximum REST requests per windowMs per IP
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ── Socket ─────────────────────────────────────────────────────────────────
# Milliseconds between allowed claim events per socket
SOCKET_CLAIM_COOLDOWN_MS=500

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=logs

# ── Redis (Optional — for horizontal scaling with socket.io-redis adapter) ─
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=
